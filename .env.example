# REZFLIX Hub — environment template.
# Copy to `.env` and fill in real values:  cp .env.example .env
#
# RULES:
#   - NEVER commit `.env` (it is gitignored). This `.env.example` holds placeholders only.
#   - NEVER prefix a secret with NEXT_PUBLIC_ — that ships it to the browser.
#   - Every var below is SERVER-ONLY. None are read by client components.

# --- App database (read by Prisma + the app) -------------------------------
# Local dev points at the Docker Postgres from infra/docker-compose.dev.yml
# (user/pass/db = rezflix/rezflix/rezflix_hub, exposed on localhost:5432).
# In PRODUCTION, host = the compose service name `hub-db`, with the real password below.
#   dev:  postgresql://rezflix:rezflix@localhost:5432/rezflix_hub?schema=public
#   prod: postgresql://rezflix:<POSTGRES_PASSWORD>@hub-db:5432/rezflix_hub?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/rezflix_hub?schema=public

# --- Postgres container (read by infra/docker-compose.prod.yml) -------------
# Only needed in production; the dev compose hardcodes throwaway dev creds.
# These must line up with the credentials embedded in DATABASE_URL above.
POSTGRES_USER=rezflix
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=rezflix_hub

# --- Auth.js v5 / NextAuth (server-only) -----------------------------------
# AUTH_SECRET signs the JWT session cookie. Generate one with:  npx auth secret
AUTH_SECRET=CHANGE_ME_generate_with_npx_auth_secret
# Canonical origin of the app. Behind the rezlab-relay (Caddy) reverse proxy.
#   dev:  http://localhost:3000
#   prod: https://www.rezflixtv.com
AUTH_URL=http://localhost:3000

# --- Admin promotion (server-only) -----------------------------------------
# Comma-separated emails. On sign-in, a user whose email is listed here is
# promoted to role `admin` (see docs/ARCHITECTURE.md §5.4). Leave empty for none.
ADMIN_EMAILS=admin@example.com

# --- Jellyfin link step (server-only) --------------------------------------
# The hub reaches Jellyfin over the private Tailnet IP to verify account ownership
# (AuthenticateByName). NEVER expose this; never call Jellyfin from the browser.
JELLYFIN_INTERNAL_URL=http://TAILNET_IP:8096
# Name the hub identifies as in the Jellyfin auth header (X-Emby-Authorization).
JELLYFIN_CLIENT_NAME=Rezflix
