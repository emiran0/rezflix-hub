# ─────────────────────────────────────────────────────────────────────────────
# REZFLIX Hub — environment template.  Copy to `.env` and fill in real values.
# NEVER commit `.env`.  NEVER prefix a secret with NEXT_PUBLIC_ (that ships it to
# the browser).  Only values that are safe to be public may use NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────────────────────

# --- App ---
NODE_ENV=development
# Public base URL of the hub (safe to expose).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (server-only) ---
# Local dev matches infra/docker-compose.dev.yml.
DATABASE_URL=postgresql://rezflix:rezflix@localhost:5432/rezflix_hub?schema=public

# --- BetterAuth (server-only) ---
# Generate a long random value, e.g.:  openssl rand -base64 32
BETTER_AUTH_SECRET=<generate-a-long-random-secret>
BETTER_AUTH_URL=http://localhost:3000

# --- Jellyfin (server-only) ---
# Reached over the Tailnet (private). Use the GPC Tailnet IP now; the new server's
# Tailnet IP after migration. This is the ONLY thing that changes at cutover.
JELLYFIN_INTERNAL_URL=http://<gpc-tailnet-ip>:8096
# Optional: name the hub identifies as to Jellyfin in the auth header.
JELLYFIN_CLIENT_NAME=RezflixHub

# --- Service quick-launch links (safe to be public; used in the links grid) ---
NEXT_PUBLIC_WATCH_URL=https://watch.rezflixtv.com
NEXT_PUBLIC_REQUEST_URL=https://request.rezflixtv.com

# --- v2 placeholders (not used in v1) ---
# TRACEARR_URL=https://tracearr.rezflixtv.com
# TRACEARR_API_KEY=<server-only>
