// REZFLIX Hub — Prisma schema.
// The Hub owns identity (username/password). Auth.js reads this `User` table directly in
// the Credentials `authorize` callback (no Prisma adapter); because we use the Credentials
// provider with JWT sessions there is no `Session` table (the session lives in a signed
// httpOnly cookie). See docs/ARCHITECTURE.md §4–5.
//
// Schema changes: always `prisma migrate dev` (local) / `migrate deploy` (prod). Never `db push`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A Hub user. `member` is defined by a non-null `jellyfinUserId` (linking Jellyfin = membership);
// `admin` is derived at sign-in from the ADMIN_EMAILS env var and persisted to `role`.
model User {
  id           String @id @default(cuid())
  username     String @unique
  email        String @unique
  passwordHash String
  displayName  String?

  role              Role              @default(applicant)
  applicationStatus ApplicationStatus @default(none)

  // Jellyfin link (proof-of-ownership). The Jellyfin password is never stored.
  // Unique so one Jellyfin account maps to at most one Hub user.
  jellyfinUserId   String?   @unique
  jellyfinLinkedAt DateTime?

  avatar String?

  // The join application (questionnaire), if this user has started one. One per user.
  application Application?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// An applicant's request to join (PRD §5 / ARCHITECTURE §4). One per user (`userId` unique).
// `answers` is jsonb so the questionnaire can evolve without a migration — the question set
// lives in app code (task 4.2). `reviewedBy` is the reviewing admin's user id (plain string,
// not a relation, to avoid a self-relation on User for v1). Approval doesn't grant `member`;
// the Jellyfin link does (ARCHITECTURE §5.5).
model Application {
  id         String            @id @default(cuid())
  userId     String            @unique
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    Json
  status     ApplicationStatus @default(pending)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([status])
}

enum Role {
  applicant
  member
  admin
}

enum ApplicationStatus {
  none
  pending
  approved
  rejected
}
