# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
next-env.d.ts

# production build
/build
/dist

# environment — never commit real secrets; keep .env.example tracked
.env
.env.*
!.env.example

# database / prisma
# (schema + migrations ARE committed; only local artifacts are ignored)
/prisma/*.db
/prisma/*.db-journal
/prisma/dev.db*

# testing
/coverage
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/

# typescript
*.tsbuildinfo

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# caches / tooling
.eslintcache
.cache/
.turbo/

# editor / OS
.DS_Store
*.pem
.vscode/*
!.vscode/extensions.json
.idea/

# misc
*.local
